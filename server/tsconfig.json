{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@pikopark/shared": ["../shared/index.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../shared" }]
}
